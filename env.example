# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_DEBUG=false
BOT_SESSION_TIMEOUT=30m
ADMIN_CHAT_ID=0
PUBLIC_CHAT_ID=0
# Public HTTPS URL for Telegram Mini App, for example https://example.com/miniapp/gifts
MINIAPP_URL=

# PostgreSQL Database Configuration
POSTGRES_DB=gravel_bot
POSTGRES_USER=gravel
POSTGRES_PASSWORD=gravel_password
POSTGRES_PORT=5432

# Database Connection (for backend services)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gravel_bot
DB_USER=gravel
DB_PASSWORD=gravel_password
DB_SSLMODE=disable

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_PUBLIC_PORT=18080
# Must be public HTTPS in non-local Telegram Mini App environments
NEXT_PUBLIC_API_URL=http://localhost:18080
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
# Include the Mini App frontend origin when not using "*"; miniapp calls send X-Telegram-Init-Data
ALLOWED_ORIGINS=*

# File storage
FILE_STORAGE_PATH=/app/storage

# Environment
ENV=local

# Production nginx and SSL
# Use one public HTTPS domain for dashboard, miniapp and API path routing.
PUBLIC_DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
SSL_STAGING=false
SSL_RSA_KEY_SIZE=4096
SSL_RENEW_BEFORE_SECONDS=2592000
CLIENT_MAX_BODY_SIZE=20m
