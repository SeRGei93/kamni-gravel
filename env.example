# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_DEBUG=false
BOT_SESSION_TIMEOUT=30m
ADMIN_CHAT_ID=0
PUBLIC_CHAT_ID=0

# PostgreSQL Database Configuration
POSTGRES_DB=gravel_bot
POSTGRES_USER=gravel
POSTGRES_PASSWORD=gravel_password
POSTGRES_PORT=5432

# Database Connection (for backend services)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gravel_bot
DB_USER=gravel
DB_PASSWORD=gravel_password
DB_SSLMODE=disable

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
ALLOWED_ORIGINS=*

# Environment
ENV=local
